# Copy to .env, replace every CHANGE_ME value, then chmod 600 .env.
# Generate secrets: openssl rand -hex 32
POSTGRES_DB=soaring_voyage
POSTGRES_USER=soaring_voyage_admin
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD_32_CHARS
APP_DB_PASSWORD=CHANGE_ME_APP_DATABASE_PASSWORD_32_CHARS
POSTGRES_PORT=5432
DATABASE_URL=postgresql://soaring_voyage_app:CHANGE_ME_APP_DATABASE_PASSWORD_32_CHARS@postgres:5432/soaring_voyage
MIGRATION_DATABASE_URL=postgresql://soaring_voyage_admin:CHANGE_ME_DATABASE_PASSWORD_32_CHARS@postgres:5432/soaring_voyage

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_32_CHARS
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD_32_CHARS@redis:6379/0
REDIS_PORT=6379

QDRANT_URL=http://qdrant:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

SECRET_KEY=CHANGE_ME_WITH_OPENSSL_RAND_HEX_32
APP_ENV=development
DEEPSEEK_API_KEY=
QIANWEN_API_KEY=
DEBUG=false
LOG_LEVEL=INFO
API_PREFIX=/api/v1
ALLOWED_ORIGINS=https://school-grader.internal
ALLOWED_HOSTS=school-grader.internal,localhost
APP_PORT=8000
APP_IMAGE_TAG=local

CONFIDENCE_THRESHOLD=0.85
MAX_HINT_LEVEL=3
MAX_LLM_RETRIES=3
LLM_TIMEOUT_SECONDS=30
USE_MOCK_LLM=false

DB_MIN_SIZE=5
DB_MAX_SIZE=25
DB_COMMAND_TIMEOUT=30
DB_MAX_INACTIVE_LIFETIME=300
